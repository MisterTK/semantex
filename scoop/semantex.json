    "architecture": {
        "64bit": {
            "url": "https://github.com/MisterTK/semantex/releases/download/v1.0.0/semantex-v1.0.0-x86_64-pc-windows-msvc.zip",
            "hash": "X86_64_WINDOWS_SHA256",
