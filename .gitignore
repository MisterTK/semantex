# Claude Code
.claude/
CLAUDE.md

# Internal dev docs and website
/docs
/examples
/site
/FASTEMBED_INTEGRATION.md

# Benchmarks (contain hardcoded local paths and dev-only scripts).
# Ignore contents but not the directory itself, so we can carve exceptions.
/benchmarks/*
# Exception: SWE-bench Verified harness is a committed sub-project.
!/benchmarks/swe_bench/
# Exception: relevance harness is a committed sub-project (its own results/ + .venv ignored).
!/benchmarks/relevance/
# Exception: agent CCB benchmark + unit tests are committed source.
!/benchmarks/claude_bench.py
!/benchmarks/tests/
# Exception: substitution-vs-recall probe (committed source — see results/probe-substitution/).
!/benchmarks/probe_substitution.py
# Exception: three-way (semantex/graphify/serena) equal-adoption harness (committed source;
# its results/three-way/ raw output stays ignored).
!/benchmarks/three_way.py
!/benchmarks/three_way_nudge.py
# Exception: v1 benchmark-validation results writeup (committed report, not raw run data).
!/benchmarks/RESULTS-v1.md
/benches
/bench_results
/scripts
# /results CONTENTS are ignored (use /results/* so the dir stays walkable for the
# negations below) EXCEPT the committed substitution-vs-recall probe analysis.
/results/*
!/results/probe-substitution/
/results/probe-substitution/*
!/results/probe-substitution/report.md
!/results/probe-substitution/parsed.json
# Raw session-dump transcripts stay ignored: they embed local paths,
# session ids, and env metadata. Only the parsed.json/report.md summaries
# are published.

# Test output
crates/semantex-core/tests/TEST_RESULTS.md

# Local settings
settings.local.json
.mcp.json

# AI editors
.gemini/
.cursor/
**/.remember/

# Exception: clean-harness large-repo validation summary
!/results/cbench-clean-largerepo/
/results/cbench-clean-largerepo/*
!/results/cbench-clean-largerepo/report.md

# Exception: three-way comparison summary
!/results/three-way/
/results/three-way/*
!/results/three-way/report.md
